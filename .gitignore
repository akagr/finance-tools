# Go
/bin/
*.exe
*.out
*.test
*.prof
vendor/
# compiled CLI binary (built into the module dir by `go build`)
schedule-fa/schedulefa

# Editor / OS
.DS_Store
.idea/
.vscode/

# Sensitive — never commit real broker data, tokens, or generated reports.
# Real Flex exports and generated reports contain account numbers and holdings.
# NOTE: gitignore does NOT support inline comments — keep comments on their own line.
private/
*.flex.xml
statement*.xml
Schedule_FA*.xml
flex-*.xml
*.token
secrets.*

# Third-party / user data (not vendored — see each dir's README)
schedule-fa/data/ttbr/*.csv
schedule-fa/data/prices/*.csv
/schedulefa

# correlation: fetched market data and built binary (not vendored)
correlation/data/*.csv
correlation/correlation

# Python bytecode
__pycache__/
*.pyc
